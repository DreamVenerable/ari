<div id="transaction-form-modal" class="hidden fixed inset-0 z-50 overflow-auto flex items-center justify-center" data-action="click->voice-recorder#closeModalOnOutsideClick">
  <div data-voice-recorder-target="transcriptionSection" class="hidden w-2/3 h-2/3 bg-white dark:bg-slate-800 p-6 rounded-xl shadow-xl overflow-y-auto relative" data-action="click->voice-recorder#stopPropagation">
    <div class="flex justify-between items-center mb-1">
      <h3 class="text-lg font-semibold text-slate-700 dark:text-slate-200">📝 Transcription:</h3>
      <button type="button" class="text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-200" data-action="click->voice-recorder#closeModal">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
        </svg>
      </button>
    </div>
    <div data-voice-recorder-target="transcriptionText" class="bg-slate-100 dark:bg-slate-700 rounded-md p-3 text-slate-700 dark:text-slate-200 mb-4"></div>

  </div>

  <div data-voice-recorder-target="previewSection" class="hidden w-2/3 h-2/3 bg-white dark:bg-slate-800 p-6 rounded-xl shadow-xl overflow-y-auto relative" data-action="click->voice-recorder#stopPropagation">
    <div class="flex justify-between items-center mb-4">
      <h3 class="text-lg font-semibold text-slate-700 dark:text-slate-200">💡 Transaction Preview:</h3>
      <button type="button" class="text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-200" data-action="click->voice-recorder#closeModal">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
        </svg>
      </button>
    </div>

    <% if Current.user %>
      <div data-voice-recorder-target="transactionForm">
        <%= form_with model: Transaction.new, url: create_from_voice_voice_path, local: false, html: { id: "transactionForm", class: "space-y-4" } do |form| %>
        
        <div>
          <%= form.label :amount, "Amount ($)", class: "block font-medium text-slate-600 dark:text-slate-300" %>
          <%= form.number_field :amount, step: 0.01, class: "mt-1 w-full px-3 py-2 rounded border text-slate-700 dark:text-slate-200 dark:bg-slate-700 focus:ring-teal-300", data: { voice_recorder_target: "previewAmount" } %>
        </div>

        <div>
          <%= form.label :transaction_type, "Type", class: "block font-medium text-slate-600 dark:text-slate-300" %>
          <%= form.select :transaction_type, [['Income', 'Income'], ['Expense', 'Expense']], { prompt: 'Select type' }, class: "mt-1 w-full px-3 py-2 rounded border text-slate-700 dark:text-slate-200 dark:bg-slate-700 focus:ring-teal-300", data: { voice_recorder_target: "previewType" } %>
        </div>

        <div>
          <%= form.label :category, "Category", class: "block font-medium text-slate-600 dark:text-slate-300" %>
          <%= form.text_field :category, class: "mt-1 w-full px-3 py-2 rounded border text-slate-700 dark:text-slate-200 dark:bg-slate-700", data: { voice_recorder_target: "previewCategory" } %>
        </div>

        <div>
          <%= form.label :description, "Description", class: "block font-medium text-slate-600 dark:text-slate-300" %>
          <%= form.text_area :description, rows: 3, class: "mt-1 w-full px-3 py-2 rounded border text-slate-700 dark:text-slate-200 dark:bg-slate-700", data: { voice_recorder_target: "previewDescription" } %>
        </div>

        <div>
          <%= form.label :date, "Date", class: "block font-medium text-slate-600 dark:text-slate-300" %>
          <%= form.datetime_field :date, value: (Time.current.strftime('%Y-%m-%dT%H:%M')), class: "mt-1 w-full px-3 py-2 rounded border text-slate-700 dark:text-slate-200 dark:bg-slate-700", data: { voice_recorder_target: "previewDate" } %>
        </div>

        <%= form.hidden_field :is_recurring, data: { voice_recorder_target: "isRecurringField" } %>
        <div class="flex flex-wrap gap-2 pt-4">
          <%= form.submit "💾 Save Transaction", class: "bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded shadow transition" %>
        </div>
      <% end %>
      </div>

      <div data-voice-recorder-target="recurringTransactionForm" class="hidden">
        <%= form_with model: RecurringTransaction.new, url: create_from_voice_voice_path, local: false, html: { id: "recurringTransactionForm", class: "space-y-4" } do |form| %>
          <div>
            <%= form.label :amount, "Amount ($)", class: "block font-medium text-slate-600 dark:text-slate-300" %>
            <%= form.number_field :amount, step: 0.01, class: "mt-1 w-full px-3 py-2 rounded border text-slate-700 dark:text-slate-200 dark:bg-slate-700 focus:ring-teal-300", data: { voice_recorder_target: "recurringPreviewAmount" } %>
          </div>

          <div>
            <%= form.label :transaction_type, "Type", class: "block font-medium text-slate-600 dark:text-slate-300" %>
            <%= form.select :transaction_type, [['Income', 'income'], ['Expense', 'expense']], { prompt: 'Select type' }, class: "mt-1 w-full px-3 py-2 rounded border text-slate-700 dark:text-slate-200 dark:bg-slate-700 focus:ring-teal-300", data: { voice_recorder_target: "recurringPreviewType" } %>
          </div>

          <div>
            <%= form.label :category, "Category", class: "block font-medium text-slate-600 dark:text-slate-300" %>
            <%= form.text_field :category, class: "mt-1 w-full px-3 py-2 rounded border text-slate-700 dark:text-slate-200 dark:bg-slate-700", data: { voice_recorder_target: "recurringPreviewCategory" } %>
          </div>

          <div>
            <%= form.label :description, "Description", class: "block font-medium text-slate-600 dark:text-slate-300" %>
            <%= form.text_area :description, rows: 3, class: "mt-1 w-full px-3 py-2 rounded border text-slate-700 dark:text-slate-200 dark:bg-slate-700", data: { voice_recorder_target: "recurringPreviewDescription" } %>
          </div>

          <div>
            <%= form.label :frequency, "Frequency", class: "block font-medium text-slate-600 dark:text-slate-300" %>
            <%= form.select :frequency, [['Daily', 'daily'], ['Weekly', 'weekly'], ['Monthly', 'monthly'], ['Yearly', 'yearly']], { prompt: 'Select frequency' }, class: "mt-1 w-full px-3 py-2 rounded border text-slate-700 dark:text-slate-200 dark:bg-slate-700 focus:ring-teal-300", data: { voice_recorder_target: "recurringPreviewFrequency" } %>
          </div>

          <div>
            <%= form.label :start_date, "Start Date", class: "block font-medium text-slate-600 dark:text-slate-300" %>
            <%= form.date_field :start_date, value: Date.current, class: "mt-1 w-full px-3 py-2 rounded border text-slate-700 dark:text-slate-200 dark:bg-slate-700 focus:ring-teal-300", data: { voice_recorder_target: "recurringPreviewStartDate" } %>
          </div>

          <div data-voice-recorder-target="recurringEndDateField">
            <%= form.label :end_date, "End Date", class: "block font-medium text-slate-600 dark:text-slate-300" %>
            <%= form.text_field :end_date, type: "date", class: "mt-1 block w-full rounded-md border text-slate-700 dark:text-slate-200 dark:bg-slate-700 focus:border-teal-500 focus:ring-teal-500 sm:text-sm", data: { voice_recorder_target: "recurringPreviewEndDate" } %>
          <button type="button" data-action="click->voice-recorder#removeRecurringEndDate" data-voice-recorder-target="removeRecurringEndDateButton" class="mt-2 text-red-600 hover:text-red-800 text-sm">Remove End Date</button>
          </div>

        <button type="button" data-action="click->voice-recorder#addRecurringEndDate" data-voice-recorder-target="addRecurringEndDateButton" class="hidden mt-2 text-blue-600 hover:text-blue-800 text-sm">Add End Date</button>

          <%= form.hidden_field :is_recurring, data: { voice_recorder_target: "isRecurringField" } %>
          <div class="flex flex-wrap gap-2 pt-4">
            <%= form.submit "💾 Save Recurring Transaction", class: "bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded shadow transition" %>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="bg-yellow-100 dark:bg-yellow-900 p-4 rounded">
        <p class="text-yellow-800 dark:text-yellow-200 font-semibold">🔒 You need to log in to save this transaction.</p>
        <div class="mt-3 flex flex-wrap gap-2">
          <%= link_to "Log In", new_session_path, class: "px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded" %>
        </div>
      </div>
    <% end %>
  </div>
</div>