<div class="bg-white shadow-md rounded-lg p-6">
  <p class="mb-2">
    <strong class="text-gray-700">Amount:</strong>
    <%= number_to_currency(@recurring_transaction.amount) %>
  </p>

  <p class="mb-2">
    <strong class="text-gray-700">Category:</strong>
    <%= @recurring_transaction.category %>
  </p>

  <p class="mb-2">
    <strong class="text-gray-700">Transaction type:</strong>
    <%= @recurring_transaction.transaction_type %>
  </p>

  <p class="mb-2">
    <strong class="text-gray-700">Frequency:</strong>
    <%= @recurring_transaction.frequency %>
  </p>

  <p class="mb-2">
    <strong class="text-gray-700">Start date:</strong>
    <%= @recurring_transaction.start_date %>
  </p>

  <% if @recurring_transaction.end_date %>
    <p class="mb-2">
      <strong class="text-gray-700">End date:</strong>
      <%= @recurring_transaction.end_date %>
    </p>
  <% end %>

  <p class="mb-2">
    <strong class="text-gray-700">Description:</strong>
    <%= @recurring_transaction.description? ? @recurring_transaction.description : 'No description' %>
  </p>

  <div class="mt-6">
    <%= link_to 'Edit this recurring transaction', edit_recurring_transaction_path(@recurring_transaction), class: "bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded mr-2" %>
    <%= link_to 'Back to recurring transactions', recurring_transactions_path, class: "bg-gray-300 hover:bg-gray-400 text-gray-800 font-bold py-2 px-4 rounded" %>

    <%= button_to 'Destroy this recurring transaction', @recurring_transaction, method: :delete, data: { turbo_confirm: 'Are you sure?' }, class: "bg-red-500 hover:bg-red-700 text-white font-bold py-2 px-4 rounded mt-2" %>
  </div>
</div>